# ── AI question generation (existing server.js on port 3000) ──────────────
# Set to "true" to generate questions via the Anthropic-backed Express server.
# VITE_USE_BACKEND_API=true

# Base URL for the AI question generation server (port 3000)
# VITE_API_BASE_URL=http://localhost:3000

# ── New TypeScript backend (port 4000) ────────────────────────────────────
# Set to "true" to sync sessions, flashcards, and analytics to the backend.
# localStorage is always written — backend is additive, never replaces it.
# VITE_USE_BACKEND=true

# Base URL for the new TypeScript backend (port 4000)
# VITE_BACKEND_URL=http://localhost:4000
