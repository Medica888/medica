# ── AI question generation ────────────────────────────────────────────────
# Set to "true" to enable live question generation via the backend.
# VITE_USE_BACKEND_API=true

# ── TypeScript backend (port 4000) ────────────────────────────────────────
# Set to "true" to sync sessions, flashcards, and analytics to the backend.
# localStorage is always written — backend is additive, never replaces it.
# VITE_USE_BACKEND=true

# Base URL for the TypeScript backend (port 4000)
# VITE_BACKEND_URL=http://localhost:4000

# ── Dev / fallback ────────────────────────────────────────────────────────
# Set to "true" to allow the local mock question bank as a fallback when
# the backend generator is unavailable (auto-enabled in dev mode).
# VITE_ALLOW_MOCK_FALLBACK=true
