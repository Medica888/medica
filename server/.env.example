# Server
PORT=4000
NODE_ENV=development

# JWT (required)
JWT_SECRET=change-me-in-production

# PostgreSQL (optional — omit to use in-memory repositories for dev/test)
# Required for persistent generated-question-bank storage and production deployments.
# DATABASE_URL=postgresql://user:pass@localhost:5432/medica

# AI generation (required for live AI question/flashcard generation)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Dev-only: return raw auth tokens (password-reset, email-verification) in API responses.
# Set true ONLY in development/staging — never in production (leaks tokens).
# AUTH_DEV_TOKENS_ENABLED=true

# Admin user IDs (comma-separated UUIDs) — required for /api/admin/* routes
# Users listed here can access the taxonomy candidate review and admin question audit tools.
# If this variable is unset or empty, ALL admin routes return 403 (fail-closed).
# ADMIN_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy

# Email — SMTP (required in production for password reset and email verification)
# Any SMTP relay works: AWS SES, SendGrid, Mailgun, Gmail, Mailhog (local dev).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@medica.app

# Frontend base URL — used to build reset/verify links in emails
# Set to your production domain in production (e.g. https://app.medica.com).
# APP_BASE_URL=http://localhost:5173
